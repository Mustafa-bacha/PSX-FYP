FLASK_ENV=production

# Security
SECRET_KEY=change-me-super-secret
JWT_SECRET_KEY=change-me-super-secret-jwt
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
JWT_ACCESS_TOKEN_EXPIRES_HOURS=12

# CORS (comma separated)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
FRONTEND_URL=http://127.0.0.1:5173

# Node/Express API
SERVER_PORT=5001
# DB_PATH=/home/sertv2cs/Desktop/Mustafa/hassan/psx-platform/data/psx_platform.db
# MARKET_PERFORMERS_CACHE_PATH=/home/sertv2cs/Desktop/Mustafa/hassan/psx-platform/server/cache/market_performers.json

# Logging
LOG_LEVEL=INFO
JSON_LOGS=true

# Async processing
ASYNC_MODE=thread
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Caching
NEWS_CACHE_HOURS=6
SENTIMENT_CACHE_HOURS=6
LIVE_QUOTE_CACHE_MINUTES=10
MARKET_PERFORMERS_CACHE_MINUTES=30

# RAG chatbot
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150

# Auth / JWT / Google OAuth
JWT_ACCESS_TOKEN_EXPIRES_HOURS=12
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://127.0.0.1:5001/api/auth/google/callback
